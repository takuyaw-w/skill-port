{
  "name": "skill-port",
  "private": true,
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",

    "dev:all": "pnpm --parallel --filter @skill-port/api --filter @skill-port/admin-web --filter @skill-port/employee-web dev",

    "api:dev": "pnpm --filter @skill-port/api dev",
    "api:test": "pnpm --filter @skill-port/api test",
    "api:db:generate": "pnpm --filter @skill-port/api db:generate",
    "api:db:migrate": "pnpm --filter @skill-port/api db:migrate",
    "api:db:studio": "pnpm --filter @skill-port/api db:studio",
    "api:db:seed": "pnpm --filter @skill-port/api db:seed",

    "admin-web:dev": "pnpm --filter @skill-port/admin-web dev",
    "employee-web:dev": "pnpm --filter @skill-port/employee-web dev",

    "auth:secret": "pnpm dlx @better-auth/cli@latest secret",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint apps packages --fix"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.0.0"
}
